# === Core ===
APP_ENV=dev
HTTP_PORT=8080
LOG_LEVEL=debug
JWT_SECRET=change-me-in-production-use-32plus-bytes

# === Database ===
DATABASE_URL=postgres://dentdesk:dentdesk@postgres:5432/dentdesk?sslmode=disable

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === WhatsApp Cloud API ===
# https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_TOKEN=your-permanent-token
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=dentdesk-verify-token-change-me
WHATSAPP_API_VERSION=v20.0

# === LLM ===
# Провайдер: anthropic | groq | mock
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Groq (fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Scheduler ===
# local | mock | macdent — по умолчанию для новых клиник
SCHEDULER_DEFAULT=local

# === CRM ===
CRM_ORIGIN=http://localhost:5173
WEB_PORT=3000
API_PORT=8080
PG_PORT=5432
WAWEB_PORT=3001

# === Worker ===
REMINDER_24H_CRON=*/15 * * * *
REMINDER_2H_CRON=*/5 * * * *
FOLLOWUP_CRON=0 10 * * *
