# ─── App ───────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ─── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=dentdesk
DB_PASSWORD=secret
DB_NAME=dentdesk_db
DB_SSLMODE=disable

# ─── Redis (optional, for future queues) ───────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_in_production_at_least_32_chars
JWT_EXPIRES_IN_HOURS=24

# ─── WhatsApp Cloud API ────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_bearer_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ─── LLM (Groq / OpenAI / Claude) ────────────────────
LLM_PROVIDER=groq               # groq | openai | anthropic
LLM_API_KEY=your_llm_api_key
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# ─── Multi-tenancy ────────────────────────────────────
TENANT_MODE=jwt                 # jwt | subdomain
